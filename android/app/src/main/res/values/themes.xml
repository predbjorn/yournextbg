<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Activity-level base theme. The actual Cardstock visuals come from
         CardstockTheme (Compose). This XML theme exists only so the system
         splash + insets + edge-to-edge defaults are sensible. -->
    <style name="Theme.YourNextBg" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
