# ─── Supabase ────────────────────────────────────────────────
# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://gkickjaihbgapowsqwhx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER commit, NEVER expose to the browser
# Found at: https://supabase.com/dashboard/project/gkickjaihbgapowsqwhx/settings/api
SUPABASE_SERVICE_ROLE_KEY=

# ─── BGG ─────────────────────────────────────────────────────
# Identifier sent in User-Agent for BGG XML API requests. Be respectful.
BGG_USER_AGENT=yournextbg/0.1 (+https://yournextbg.com)
# BGG XML API access token (issued by BGG admins on request). Sent as
# `Authorization: Bearer ${BGG_API_KEY}`. Without it, xmlapi2 returns 401.
BGG_API_KEY=

# Public feature flag: set to "1" to expose the "Sync from BGG" UI. Only flip
# on once the deployed bgg-sync edge function has its BGG_API_KEY secret set.
NEXT_PUBLIC_BGG_SYNC_ENABLED=

# ─── LLM scoring (later) ─────────────────────────────────────
# ANTHROPIC_API_KEY=
